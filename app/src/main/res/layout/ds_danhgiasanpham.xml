<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="8dp"
    android:layout_marginBottom="10dp"
    >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/boc"

        android:padding="16dp">
<LinearLayout
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal">

    <ImageView

        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
    android:background="@drawable/nd"
        android:layout_marginRight="10dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tenkhachhang"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="khang"
        android:textSize="16sp"
        android:textColor="#4D00E2"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

</LinearLayout>
        <!-- Tiêu đề đánh giá -->

        <!-- 5 Sao Đánh Giá -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <ImageButton
                android:id="@+id/star1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/star1"
                android:contentDescription="Star 1"
                android:background="@null" />

            <ImageButton
                android:id="@+id/star2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/star1"
                android:contentDescription="Star 2"
                android:background="@null" />

            <ImageButton
                android:id="@+id/star3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/star1"
                android:contentDescription="Star 3"
                android:background="@null" />

            <ImageButton
                android:id="@+id/star4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/star1"
                android:contentDescription="Star 4"
                android:background="@null" />

            <ImageButton
                android:id="@+id/star5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/star1"
                android:contentDescription="Star 5"
                android:background="@null" />
        </LinearLayout>
        <TextView

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đánh giá của khách hàng"
            android:textSize="13sp"
            android:textColor="#FF3022"
            android:textStyle="bold"
            android:layout_marginBottom="5dp" />

        <!-- Nội dung đánh giá -->
        <EditText
            android:id="@+id/txtNoidungdanhgia"
            android:background="@drawable/danhgia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
          android:text="Tuyệt voơiời luoôn"
            android:padding="10dp"

            android:clickable="false"
            android:longClickable="false"
            android:textColor="#000000"
            android:inputType="textMultiLine"
            android:gravity="top"

            android:layout_marginBottom="0dp" />

        <!-- Nút gửi đánh giá -->

    </LinearLayout>
    <TextView
        android:id="@+id/masp"
        android:layout_width="0dp"
        android:layout_height="0dp"
        />
    <TextView
        android:id="@+id/id_chitiet"
        android:layout_width="0dp"
        android:layout_height="0dp"
        />
    <TextView
        android:id="@+id/id_danhgia"
        android:layout_width="0dp"
        android:layout_height="0dp"
        />
</androidx.cardview.widget.CardView>